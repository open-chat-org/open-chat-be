// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider     = "prisma-client"
  output       = "../src/generated/prisma"
  moduleFormat = "cjs"
}

datasource db {
  provider = "postgresql"
}

model User {
  public_key        String   @unique @map("public_key")
  x25519_public_key String?  @unique @map("x25519_public_key")
  username          String?  @unique @map("username")
  name              String?  @map("name")
  quote             String?  @map("quote")
  phone             String?  @map("phone")
  email             String?  @map("email")
  verfiication_id   String?  @map("verfiication_id")
  createdAt         DateTime @default(now()) @map("created_at")
  updatedAt         DateTime @updatedAt @map("updated_at")
}

model DirectMessage {
  id                       String   @id @map("id")
  sender_public_key        String   @map("sender_public_key")
  sender_x25519_public_key String   @map("sender_x25519_public_key")
  recipient_public_key     String   @map("recipient_public_key")
  message                  String   @map("message")
  message_hash             String   @map("message_hash")
  sender_signature         String   @map("sender_signature")
  send_time                DateTime @map("send_time")
  algorithm                String   @map("algorithm")
  createdAt                DateTime @default(now()) @map("created_at")
  expiresAt                DateTime @map("expires_at")

  @@index([recipient_public_key, createdAt])
  @@index([expiresAt])
}

model ServerNode {
  peer_id           String    @id @map("peer_id")
  server_public_key String?   @map("server_public_key")
  listen_addresses  Json?     @map("listen_addresses")
  last_seen_at      DateTime  @map("last_seen_at")
  last_announce_at  DateTime? @map("last_announce_at")
  is_active         Boolean   @default(false) @map("is_active")
  createdAt         DateTime  @default(now()) @map("created_at")
  updatedAt         DateTime  @updatedAt @map("updated_at")

  @@index([is_active, last_seen_at])
}

model ServerScoreReport {
  id                         String   @id @default(cuid()) @map("id")
  reporter_peer_id           String   @map("reporter_peer_id")
  reporter_server_public_key String   @map("reporter_server_public_key")
  target_peer_id             String   @map("target_peer_id")
  score                      Int      @map("score")
  observed_at                DateTime @map("observed_at")
  expires_at                 DateTime @map("expires_at")
  payload_hash               String   @map("payload_hash")
  signature                  String   @map("signature")
  createdAt                  DateTime @default(now()) @map("created_at")
  updatedAt                  DateTime @updatedAt @map("updated_at")

  @@unique([reporter_peer_id, target_peer_id, observed_at])
  @@index([target_peer_id, expires_at])
  @@index([reporter_peer_id, target_peer_id, observed_at])
}

model ServerScoreAggregate {
  target_peer_id String   @id @map("target_peer_id")
  mean_score     Float    @map("mean_score")
  report_count   Int      @map("report_count")
  updated_at     DateTime @map("updated_at")
  last_report_at DateTime @map("last_report_at")
}
